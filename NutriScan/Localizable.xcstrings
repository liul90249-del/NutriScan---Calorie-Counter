    "Your meal log and photo analysis stay on-device. Health data sync and cloud backup are not enabled yet." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your meal log and photo analysis stay on-device. Health data sync and cloud backup are not enabled yet."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu registro de comidas y el análisis de fotos permanecen en el dispositivo. La sincronización de salud y la copia en la nube aún no están activadas."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il diario pasti e l'analisi foto restano sul dispositivo. La sincronizzazione salute e il backup cloud non sono ancora attivi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "食事ログと写真解析は端末内に保存されます。ヘルス同期とクラウドバックアップはまだ有効ではありません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的餐食记录和照片分析都会保留在本机。健康同步和云备份暂未启用。"
          }
        }
      }
    },
    "Your meal log stays on-device, but selected photos may be sent to a cloud AI service for recognition once that integration is connected." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your meal log stays on-device, but selected photos may be sent to a cloud AI service for recognition once that integration is connected."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu registro de comidas permanece en el dispositivo, pero algunas fotos seleccionadas pueden enviarse a un servicio de IA en la nube cuando la integración esté conectada."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il diario pasti resta sul dispositivo, ma alcune foto selezionate possono essere inviate a un servizio IA cloud quando l'integrazione è connessa."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "食事ログは端末内に保持されますが、統合接続後は一部の写真が認識のためクラウド AI サービスに送信される場合があります。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的餐食记录仍保留在本机，但接入完成后，部分选中的照片可能会发送到云端 AI 服务进行识别。"
          }
        }
      }
    },
    "Your meal log stays on-device. Photo analysis uses local recognition first and can fall back to cloud AI when that service is connected." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your meal log stays on-device. Photo analysis uses local recognition first and can fall back to cloud AI when that service is connected."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu registro de comidas permanece en el dispositivo. El análisis de fotos usa primero el reconocimiento local y puede recurrir a IA en la nube cuando esté conectada."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il diario pasti resta sul dispositivo. L'analisi foto usa prima il riconoscimento locale e può passare all'IA cloud quando il servizio è connesso."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "食事ログは端末内に保存されます。写真解析はまずローカル認識を使い、サービス接続時はクラウドAIにフォールバックできます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的餐食记录会保留在本机。照片分析会优先使用本地识别，连接服务后也可回退到云端 AI。"
          }
        }
      }
    },
    "Your photo will be sent for cloud AI analysis before you save." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your photo will be sent for cloud AI analysis before you save."
          }
        },
